# Anthropic API Key (required for AI Threat Briefing feature)
# Get your key at: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_api_key_here

# GitHub Pages base path (e.g. /attack-engine/ for https://username.github.io/attack-engine/)
# Leave empty or use './' for local file:// use
VITE_BASE_PATH=./
